# ~/.visidatarc — gruvbox theme via terminal palette (no hex)
# vd 3.3's hex-bg parsing path doesn't render, so everything here uses
# either named colors (low-16, themed to gruvbox by ghostty) or xterm-256
# palette indices (close to gruvbox bg/fg tones).

# Accent palette — ghostty themes the low-16 slots to gruvbox neutral
RED, GREEN, YELLOW = 'red', 'green', 'yellow'
BLUE, PURPLE, AQUA = 'blue', 'magenta', 'cyan'
ORANGE = '208'  # xterm-256 orange (gruvbox orange is not in the low-16)

# BG layers — xterm-256 dark grays approximating gruvbox bg/bg1/bg2
BG, BG1, BG2 = '235', '237', '239'

# FG tones — xterm-256 cream tones approximating gruvbox fg/fg0/gray
FG, FG0, GRAY = '223', '230', '245'

# Base
options.color_default       = f'{FG} on {BG}'
options.color_default_hdr   = f'bold {YELLOW} on {BG1}'
options.color_current_hdr   = f'bold {YELLOW} on {BG2}'
options.color_bottom_hdr    = f'underline {FG} on {BG}'

# Top menu bar — dim overlay aesthetic (bg-shift, no bright bar)
options.color_menu          = f'bold {FG} on {BG1}'
options.color_menu_active   = f'bold {YELLOW} on {BG2}'
options.color_menu_spec     = f'bold {RED} on {BG1}'
options.color_menu_help     = f'italic {GRAY} on {BG1}'

# Status lines
options.color_status            = f'{FG} on {BG1}'
options.color_top_status        = f'{FG} on {BG1}'
options.color_active_status     = f'bold {GREEN} on {BG1}'
options.color_inactive_status   = f'{GRAY} on {BG1}'
options.color_highlight_status  = f'bold {GREEN} on {BG2}'
options.color_keystrokes        = f'bold {ORANGE} on {BG1}'
options.color_longname_status   = FG
options.color_longname_guide    = GRAY

# Rows — dim overlay aesthetic (bg-shift only, no reverse/bright-bar)
options.color_current_row   = f'on {BG1}'
options.color_selected_row  = f'bold on {BG2}'

# Columns
options.color_key_col       = f'bold {BLUE}'
options.color_current_col   = f'bold on {BG1}'
options.color_current_cell  = f'bold {YELLOW} on {BG2}'
options.color_hidden_col    = GRAY
options.color_column_sep    = f'{GRAY} on {BG}'

# Notifications
options.color_error          = f'bold {RED}'
options.color_warning        = YELLOW
options.color_working        = GREEN
options.color_match          = RED
options.color_change_pending = f'reverse {YELLOW}'
options.color_add_pending    = GREEN
options.color_delete_pending = RED
options.color_note_pending   = f'bold {GREEN}'
options.color_note_row       = YELLOW
options.color_note_type      = BLUE

# Editing
options.color_edit_cell      = f'{FG0} on {BG2}'
options.color_edit_unfocused = f'{GRAY} on {BG2}'

# Sidebar / heading / palette
options.color_sidebar        = f'{FG} on {BG1}'
options.color_sidebar_title  = f'bold {YELLOW} on {BG1}'
options.color_heading        = f'bold {YELLOW} on {BG2}'
options.color_cmdpalette     = f'{FG} on {BG2}'
options.color_code           = f'{FG0} on {BG2}'

# Misc
options.color_aggregator     = f'bold {AQUA} on {BG1}'
options.color_clickable      = f'bold {BLUE}'
options.color_currency_neg   = RED
options.color_status_replay  = GREEN
options.color_xword_active   = PURPLE
options.color_guide_unwritten = GRAY
